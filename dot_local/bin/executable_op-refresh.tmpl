#!/usr/bin/env bash
set -euo pipefail

USE_OP="{{ .use_1password | default false }}"
if [[ "$USE_OP" != "true" ]]; then
  echo "1Password support is disabled in .chezmoidata/settings.yaml (use_1password: false)"
  exit 0
fi

if ! command -v op >/dev/null 2>&1; then
  echo "op CLI not found"
  exit 1
fi

mkdir -p "$HOME/.config/zsh/local" "$HOME/.ssh"

TEMPLATE_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}/op/templates"

if [[ ! -d "$TEMPLATE_ROOT" ]]; then
  echo "template directory not found: $TEMPLATE_ROOT"
  exit 1
fi

op inject -i "$TEMPLATE_ROOT/zsh-1password.tpl" -o "$HOME/.config/zsh/local/1password.zsh"

# Public keys are rendered on both OSes — not secret, and on macOS they serve
# as the IdentityFile selector so the 1Password agent picks the right key.
op inject -i "$TEMPLATE_ROOT/id_ssh_personal.pub.tpl" -o "$HOME/.ssh/id_ssh_personal.pub"
op inject -i "$TEMPLATE_ROOT/id_ssh_zpods.pub.tpl" -o "$HOME/.ssh/id_ssh_zpods.pub"
chmod 644 "$HOME/.ssh/id_ssh_personal.pub" "$HOME/.ssh/id_ssh_zpods.pub"

{{- if eq .chezmoi.os "linux" }}
# Linux (no 1Password desktop / agent): SSH private keys must exist on disk.
op inject -i "$TEMPLATE_ROOT/id_ssh_personal.priv.tpl" -o "$HOME/.ssh/id_ssh_personal.priv"
op inject -i "$TEMPLATE_ROOT/id_ssh_zpods.priv.tpl" -o "$HOME/.ssh/id_ssh_zpods.priv"

chmod 600 \
  "$HOME/.config/zsh/local/1password.zsh" \
  "$HOME/.ssh/id_ssh_personal.priv" \
  "$HOME/.ssh/id_ssh_zpods.priv"
{{- else }}
# macOS: the 1Password app exposes the agent socket for SSH.
# Private keys stay in the vault — no need to render them to disk.
chmod 600 "$HOME/.config/zsh/local/1password.zsh"
{{- end }}

echo "Rendered 1Password-backed local files."
