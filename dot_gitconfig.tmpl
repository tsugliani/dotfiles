[user]
    name = {{ .git.name | default "Timo Sugliani" | quote }}
    email = {{ .git.email | default "timo.sugliani@gmail.com" | quote }}
    signingkey = {{ .ssh.default_identity_public_key | default "~/.ssh/id_ed25519.pub" | quote }}

[core]
    editor = nvim
    pager = delta
    excludesfile = ~/.gitignore_global

[init]
    defaultBranch = main

[push]
    default = simple

[pull]
    rebase = true

[color]
    ui = true

[alias]
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    ll = log --stat --abbrev-commit

[delta]
    features = line-numbers diff-so-fancy decorations
    syntax-theme = Monokai Extended
    navigate = true

[interactive]
    diffFilter = delta --color-only --pager=less

[gpg]
    format = ssh

[commit]
    gpgsign = true

[hub]
    protocol = ssh

{{- if .use_1password | default false }}
# 1Password mode:
# - keep the base config static and safe
# - secrets (github.token, optional email override) live in ~/.gitconfig.1password
#   rendered via `op-refresh` (op inject). git silently ignores the include
#   if the file doesn't exist yet, so the static signingkey above keeps signing working.
[include]
    path = ~/.gitconfig.1password
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
[credential]
    helper = osxkeychain
{{- end }}

{{- if eq .chezmoi.os "linux" }}
[credential]
    helper = cache --timeout=3600

[safe]
    directory = /home/linuxbrew/.linuxbrew/Homebrew
{{- end }}
