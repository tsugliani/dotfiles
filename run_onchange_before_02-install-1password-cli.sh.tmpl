#!/usr/bin/env bash
set -euo pipefail

USE_OP="{{ .use_1password | default false }}"

if [[ "$USE_OP" != "true" ]]; then
  exit 0
fi

# Source brew shellenv so brew-installed binaries are in PATH
for brewbin in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew "$HOME/.linuxbrew/bin/brew"; do
  if [[ -x "$brewbin" ]]; then
    eval "$("$brewbin" shellenv)"
    break
  fi
done

if command -v op >/dev/null 2>&1; then
  exit 0
fi

if command -v brew >/dev/null 2>&1; then
  brew install --cask 1password-cli || brew install 1password-cli
fi
