# Machine-local generated SSH additions using op inject examples.
# Adjust item/field names to match your vault.

Host lab-bastion
  HostName "{{`{{ op://`}}{{ .op.vault | default "Private" }}/Servers/bastion-hostname{{` }}`}}"
  User "{{`{{ op://`}}{{ .op.vault | default "Private" }}/Servers/bastion-user{{` }}`}}"
  Port "{{`{{ op://`}}{{ .op.vault | default "Private" }}/Servers/bastion-port{{` }}`}}"
