# This file is rendered locally by: op-refresh
# Only contains values that actually need 1Password resolution.
# Adjust vault/item/field names to match your own 1Password entries.

[user]
    email = "{{`{{ op://`}}{{ .op.vault | default "Private" }}/{{ .op.github_personal_item | default "GitHub-Personal" }}/email{{` }}`}}"

[github]
    token = "{{`{{ op://`}}{{ .op.vault | default "Private" }}/{{ .op.github_personal_item | default "GitHub-Personal" }}/token{{` }}`}}"
