#!/usr/bin/env bash
set -euo pipefail

case "{{ .chezmoi.os }}" in
  linux)
    if command -v apt-get >/dev/null 2>&1; then
      sudo apt-get update
      sudo apt-get install -y \
        build-essential curl file git procps gettext ca-certificates
    fi
    ;;
  darwin)
    xcode-select -p >/dev/null 2>&1 || xcode-select --install || true
    ;;
esac
